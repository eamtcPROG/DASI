# Copy this file to .env.secrets and fill in your credentials.
# .env.secrets is gitignored — never commit the real file.

# Gmail address used to send emails
SMTP_USER=your-gmail@gmail.com

# Gmail App Password (not your Gmail login password).
# Generate one at: Google Account → Security → 2-Step Verification → App passwords
# Name it e.g. "CONVERSO notification service"
SMTP_PASS=xxxx xxxx xxxx xxxx

# Sender label shown in the inbox (use the same Gmail address as SMTP_USER)
SMTP_FROM=CONVERSO <your-gmail@gmail.com>
