NODE_ENV=production
PORT=3000
VERSION=1.0.0

# Browser Origins for Socket.IO (comma-separated). Must include your public site.
SOCKET_CORS_ORIGINS=https://converso.me,https://www.converso.me,http://localhost:3100,http://127.0.0.1:3100

RABBITMQ_URI=amqp://guest:guest@rabbitmq:5672
RMQ_IDENTITY_QUEUE=user
RMQ_CHAT_QUEUE=chat
RMQ_ANALYTICS_QUEUE=analytics
IDENTITY_HTTP_URL=http://identity-service:3001

REDIS_HOST=redis
REDIS_PORT=6379

ANALYTICS_HTTP_URL=http://analytics-service:3004
